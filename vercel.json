{
    "version": 2,
    "framework": null,
    "builds": [
        { "src": "api/index.php", "use": "vercel-php@0.7.1" },
        { "src": "public/**", "use": "@vercel/static" }
    ],
    "routes": [
        {
            "src": "/(.*)",
            "dest": "/api/index.php"
        }
    ]
}
